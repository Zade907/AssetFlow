# PostgreSQL 15+ (matches the optional root docker-compose service when present)
DATABASE_URL="postgresql://assetflow:assetflow@localhost:5433/assetflow?schema=public"

PORT=4000
NODE_ENV=development
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="8h"
# Comma-separated list. Leave unset in development to allow all origins.
CORS_ORIGIN="http://localhost:5173"
