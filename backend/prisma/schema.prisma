generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AuditRecordStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  employee     Employee?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Department {
  id                 String          @id @default(uuid())
  name               String          @unique
  code               String          @unique
  parentDepartmentId String?
  parent             Department?     @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Restrict)
  children           Department[]    @relation("DepartmentHierarchy")
  headEmployeeId     String?
  head               Employee?       @relation("DepartmentHead", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  employees          Employee[]      @relation("DepartmentEmployees")
  auditCycles        AuditCycle[]
  status             EmployeeStatus  @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([parentDepartmentId])
  @@index([headEmployeeId])
  @@index([status])
}

model Employee {
  id                  String               @id @default(uuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  email               String               @unique
  departmentId        String?
  department          Department?          @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  headOf              Department[]         @relation("DepartmentHead")
  role                Role                 @default(EMPLOYEE)
  status              EmployeeStatus       @default(ACTIVE)
  allocations         Allocation[]         @relation("AllocationEmployee")
  allocationsCreated  Allocation[]         @relation("AllocationCreator")
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceTechnician")
  maintenanceApproved MaintenanceRequest[] @relation("MaintenanceApprover")
  transfersFrom       TransferRequest[]    @relation("TransferFrom")
  transfersTo         TransferRequest[]    @relation("TransferTo")
  transfersApproved   TransferRequest[]    @relation("TransferApprover")
  auditCyclesCreated  AuditCycle[]         @relation("AuditCycleCreator")
  auditAssignments    AuditAssignment[]
  auditRecords        AuditRecord[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([departmentId])
  @@index([role, status])
}

model AssetCategory {
  id           String          @id @default(uuid())
  name         String          @unique
  description  String?
  customFields Json?
  status       EmployeeStatus  @default(ACTIVE)
  assets       Asset[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model Asset {
  id                  String               @id @default(uuid())
  assetTag            String               @unique
  name                String
  categoryId          String
  category            AssetCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  serialNumber        String?              @unique
  acquisitionDate     DateTime
  acquisitionCost     Decimal              @db.Decimal(12, 2)
  condition           AssetCondition       @default(GOOD)
  location            String
  photoUrl            String?
  isBookable          Boolean              @default(false)
  status              AssetStatus          @default(AVAILABLE)
  customData          Json?
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  transferRequests    TransferRequest[]
  auditRecords        AuditRecord[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([isBookable, status])
}

model Allocation {
  id                 String           @id @default(uuid())
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id], onDelete: Restrict)
  employeeId         String
  employee           Employee         @relation("AllocationEmployee", fields: [employeeId], references: [id], onDelete: Restrict)
  allocatedAt        DateTime         @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  conditionOnReturn  AssetCondition?
  notes              String?
  status             AllocationStatus @default(ACTIVE)
  allocatedById      String
  allocatedBy        Employee         @relation("AllocationCreator", fields: [allocatedById], references: [id], onDelete: Restrict)
  createdAt          DateTime         @default(now())

  @@index([assetId, status])
  @@index([employeeId, status])
  @@index([allocatedById])
}

model TransferRequest {
  id             String         @id @default(uuid())
  assetId        String
  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict)
  fromEmployeeId String
  fromEmployee   Employee       @relation("TransferFrom", fields: [fromEmployeeId], references: [id], onDelete: Restrict)
  toEmployeeId   String
  toEmployee     Employee       @relation("TransferTo", fields: [toEmployeeId], references: [id], onDelete: Restrict)
  reason         String
  status         TransferStatus @default(REQUESTED)
  approvedById   String?
  approvedBy     Employee?      @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  decisionNotes  String?
  decidedAt      DateTime?
  requestedAt    DateTime       @default(now())

  @@index([assetId, status])
  @@index([fromEmployeeId, status])
  @@index([toEmployeeId, status])
  @@index([approvedById])
}

model Booking {
  id         String        @id @default(uuid())
  assetId    String
  asset      Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  startTime  DateTime
  endTime    DateTime
  purpose    String
  status     BookingStatus @default(UPCOMING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([assetId, startTime, endTime])
  @@index([employeeId, startTime])
  @@index([status])
}

model MaintenanceRequest {
  id                   String              @id @default(uuid())
  assetId              String
  asset                Asset               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  raisedById           String
  raisedBy             Employee            @relation("MaintenanceRequester", fields: [raisedById], references: [id], onDelete: Restrict)
  description          String
  priority             MaintenancePriority @default(MEDIUM)
  photoUrl             String?
  status               MaintenanceStatus   @default(PENDING)
  assignedTechnicianId String?
  assignedTechnician   Employee?           @relation("MaintenanceTechnician", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  approvedById         String?
  approvedBy           Employee?           @relation("MaintenanceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  resolvedAt           DateTime?
  resolutionNotes      String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([assetId, status])
  @@index([raisedById, status])
  @@index([assignedTechnicianId])
  @@index([approvedById])
  @@index([priority, status])
}

model AuditCycle {
  id                String           @id @default(uuid())
  name              String
  scopeDepartmentId String?
  scopeDepartment   Department?      @relation(fields: [scopeDepartmentId], references: [id], onDelete: Restrict)
  scopeLocation     String?
  startDate         DateTime
  endDate           DateTime
  status            AuditCycleStatus @default(DRAFT)
  createdById       String
  createdBy         Employee         @relation("AuditCycleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  closedAt          DateTime?
  assignments       AuditAssignment[]
  records           AuditRecord[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([scopeDepartmentId])
  @@index([createdById])
  @@index([status, startDate])
}

model AuditAssignment {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditorId    String
  auditor      Employee   @relation(fields: [auditorId], references: [id], onDelete: Restrict)

  @@unique([auditCycleId, auditorId])
  @@index([auditorId])
}

model AuditRecord {
  id           String            @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle        @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId      String
  asset        Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)
  auditorId    String?
  auditor      Employee?         @relation(fields: [auditorId], references: [id], onDelete: SetNull)
  status       AuditRecordStatus @default(PENDING)
  notes        String?
  recordedAt   DateTime?

  @@unique([auditCycleId, assetId])
  @@index([assetId])
  @@index([auditorId, status])
}

model Notification {
  id                String   @id @default(uuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type              String
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([employeeId, isRead])
  @@index([relatedEntityType, relatedEntityId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([employeeId, createdAt])
  @@index([entityType, entityId])
}
